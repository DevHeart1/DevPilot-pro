# Core runtime
VITE_LIVE_MODE="true"
VITE_TARGET_APP_BASE_URL="http://localhost:3000"
VITE_SANDBOX_URL="http://localhost:8080"

# Gemini
VITE_GEMINI_API_KEY=""

# GitLab
VITE_GITLAB_URL="https://gitlab.com"
VITE_GITLAB_TOKEN=""
VITE_GITLAB_PROJECT_ID=""
