# Live execution flags
VITE_LIVE_REPOSITORY_MODE="true"
VITE_LIVE_GITLAB_MODE="false"
VITE_LIVE_EVENT_MODE="false"
VITE_LIVE_DUO_EXECUTION="false"
VITE_GITLAB_WEBHOOK_SECRET=""

# Optional Browserbase settings
VITE_BROWSERBASE_API_KEY=""
VITE_BROWSERBASE_PROJECT_ID=""

# Optional GitLab Duo API settings
VITE_GITLAB_DUO_API_URL="https://gitlab.com/api/v4"
VITE_GITLAB_DUO_TOKEN=""
